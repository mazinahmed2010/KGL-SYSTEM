# ==================================
# KGL Enterprise System - Frontend
# Environment Configuration
# ==================================

# ==================================
# API CONFIGURATION
# ==================================
# Backend API URL (Development)
VITE_API_URL=http://localhost:3000/api

# Backend API URL (Production)
# VITE_API_URL=https://kgl-backend.onrender.com/api

# API Timeout in milliseconds
VITE_API_TIMEOUT=30000

# ==================================
# AUTHENTICATION
# ==================================
# JWT Token key name in localStorage
VITE_TOKEN_KEY=kgl-token

# Session timeout in minutes
VITE_SESSION_TIMEOUT=30

# ==================================
# APPLICATION CONFIGURATION
# ==================================
# Application name
VITE_APP_NAME=KGL Enterprise

# Application version
VITE_APP_VERSION=2.0.0

# Default language
VITE_DEFAULT_LANG=en

# Enable/disable demo mode
VITE_DEMO_MODE=true

# ==================================
# FEATURE FLAGS
# ==================================
# Enable/disable features
VITE_ENABLE_CREDIT_SALES=true
VITE_ENABLE_PROCUREMENT=true
VITE_ENABLE_INVENTORY=true
VITE_ENABLE_REPORTS=true
VITE_ENABLE_2FA=true

# ==================================
# NOTIFICATION SETTINGS
# ==================================
# Toast notification duration (ms)
VITE_TOAST_DURATION=5000

# Enable/disable desktop notifications
VITE_ENABLE_DESKTOP_NOTIFICATIONS=true

# ==================================
# UI CONFIGURATION
# ==================================
# Default theme (light/dark/system)
VITE_DEFAULT_THEME=system

# Items per page in tables
VITE_ITEMS_PER_PAGE=25

# Date format
VITE_DATE_FORMAT=DD/MM/YYYY

# Time format (12/24)
VITE_TIME_FORMAT=24

# Currency symbol
VITE_CURRENCY_SYMBOL=UGX

# Currency position (before/after)
VITE_CURRENCY_POSITION=before

# ==================================
# MAP CONFIGURATION (if using maps)
# ==================================
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key
# VITE_MAP_CENTER_LAT=0.3136
# VITE_MAP_CENTER_LNG=32.5811
# VITE_MAP_ZOOM=12

# ==================================
# ANALYTICS (if using)
# ==================================
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXX-Y
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ==================================
# PAGINATION
# ==================================
VITE_MAX_PAGE_SIZE=100
VITE_DEFAULT_PAGE_SIZE=25

# ==================================
# FILE UPLOAD
# ==================================
VITE_MAX_UPLOAD_SIZE=5242880 # 5MB in bytes
VITE_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf

# ==================================
# REFRESH INTERVALS
# ==================================
VITE_DASHBOARD_REFRESH_INTERVAL=60000 # 1 minute in ms
VITE_INVENTORY_REFRESH_INTERVAL=30000 # 30 seconds in ms

# ==================================
# CONTACT INFORMATION
# ==================================
VITE_SUPPORT_EMAIL=support@kgl.co.ug
VITE_SUPPORT_PHONE=+256700123456
VITE_COMPANY_ADDRESS="Kampala, Uganda"

# ==================================
# SOCIAL MEDIA LINKS
# ==================================
VITE_FACEBOOK_URL=https://facebook.com/kglenterprise
VITE_TWITTER_URL=https://twitter.com/kglenterprise
VITE_LINKEDIN_URL=https://linkedin.com/company/kgl-enterprise
VITE_WHATSAPP_NUMBER=+256700123456

# ==================================
# BRANCH CONFIGURATION
# ==================================
VITE_BRANCH_MAGANJO_NAME="Maganjo Branch"
VITE_BRANCH_MAGANJO_ADDRESS="Plot 12, Kampala Road, Maganjo"
VITE_BRANCH_MATUGGA_NAME="Matugga Branch"
VITE_BRANCH_MATUGGA_ADDRESS="Plot 45, Matugga Town Centre"

# ==================================
# SENTRY ERROR TRACKING (if using)
# ==================================
# VITE_SENTRY_DSN=your-sentry-dsn
# VITE_SENTRY_ENVIRONMENT=production

# ==================================
# PWA CONFIGURATION
# ==================================
VITE_ENABLE_PWA=false
VITE_PWA_NAME="KGL Enterprise"
VITE_PWA_SHORT_NAME="KGL"
VITE_PWA_THEME_COLOR="#1B4D3E"
VITE_PWA_BACKGROUND_COLOR="#FFFFFF"

# ==================================
# DEVELOPER OPTIONS
# ==================================
# Enable Vue Devtools
VITE_ENABLE_DEVTOOLS=true

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE=false

# Enable mock API (for development without backend)
VITE_USE_MOCK_API=false

# Log level (debug/info/warn/error)
VITE_LOG_LEVEL=info